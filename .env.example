# ── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PARENT_GROUP_PATH=my-org/dbaas        # full path to the parent dbaas group
GITLAB_REQUEST_CONCURRENCY=20             # max concurrent HTTP requests to GitLab

# ── ArgoCD ───────────────────────────────────────────────────────────────────
# JSON array — must be a single line in this file (no line breaks inside the value).
# Set to [] to disable ArgoCD scanning.
ARGOCD_INSTANCES=[{"cluster_name":"cluster-prod-1","url":"https://argocd1.example.com","token":"ey..."},{"cluster_name":"cluster-prod-2","url":"https://argocd2.example.com","token":"ey..."}]
ARGOCD_APP_NAME_PREFIX=dbaas              # prefix of ArgoCD app names: "{prefix}-{project_slug}"

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=json                      # "json" or "mongodb"
STORAGE_JSON_PATH=data/databases.json     # only used when STORAGE_BACKEND=json
# STORAGE_MONGO_URI=mongodb://user:pass@host:27017    # required when STORAGE_BACKEND=mongodb
# STORAGE_MONGO_DATABASE=dbaas

# ── Console URLs ─────────────────────────────────────────────────────────────
# Placeholders: {cluster}, {db_name}, {group}
# For MongoDB, also supports {username}, {password}, {host}, {port} —
# these trigger a live OpenShift secret lookup when the Connect button is clicked.
# CONSOLE_ELASTICSEARCH_URL=https://kibana.{cluster}.example.com
# CONSOLE_POSTGRESQL_URL=https://pgadmin.{cluster}.example.com/{db_name}
# CONSOLE_MONGODB_URL=mongodb://{username}:{password}@{host}:{port}/{db_name}?authSource=admin

# ── OpenShift (for credential fetching) ───────────────────────────────────────
# cluster_name must match the ArgoCD cluster_name.
# OPENSHIFT_CLUSTERS=[{"cluster_name":"cluster-prod-1","api_url":"https://api.cluster1.example.com:6443","token":"..."}]
# Secret location templates (placeholders: {db_name}, {group}, {cluster})
# OPENSHIFT_SECRET_NAME_TEMPLATE={db_name}-credentials
# OPENSHIFT_SECRET_NAMESPACE_TEMPLATE={group}
# Secret field names inside the secret's data
# OPENSHIFT_USERNAME_FIELD=username
# OPENSHIFT_PASSWORD_FIELD=password
# OPENSHIFT_HOST_FIELD=host
# OPENSHIFT_PORT_FIELD=port

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300                 # auto-scan interval in seconds (0 = disabled)

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=changeme                  # generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin       # username for the auto-created first admin user
AUTH_BOOTSTRAP_ADMIN_PASSWORD=changeme    # set on first deploy to create admin; clear afterwards
# AUTH_USERS_JSON_PATH=data/users.json
