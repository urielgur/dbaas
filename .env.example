# ── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PARENT_GROUP_ID=123
GITLAB_REQUEST_CONCURRENCY=20   # max concurrent HTTP requests to GitLab

# ── ArgoCD ───────────────────────────────────────────────────────────────────
# JSON array of ArgoCD instances. Each entry needs cluster_name, url, and token.
ARGOCD_INSTANCES='[
  {"cluster_name": "cluster-prod-1", "url": "https://argocd1.example.com", "token": "ey..."},
  {"cluster_name": "cluster-prod-2", "url": "https://argocd2.example.com", "token": "ey..."},
  {"cluster_name": "cluster-dev-1",  "url": "https://argocd3.example.com", "token": "ey..."},
  {"cluster_name": "cluster-dev-2",  "url": "https://argocd4.example.com", "token": "ey..."}
]'

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=json                   # "json" or "mongodb"
STORAGE_JSON_PATH=data/databases.json  # only used when STORAGE_BACKEND=json
# MONGO_URI=mongodb://user:pass@host:27017   # required when STORAGE_BACKEND=mongodb
# STORAGE_MONGO_DATABASE=dbaas

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300  # background scan interval (seconds). 0 to disable.

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173"]
