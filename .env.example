# ── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-iKFgWAi_WUyUWjqHwsy0cmM6MQpvOjEKdTptOTNvcw8.01.170al17z5
GITLAB_PARENT_GROUP_ID=130353672              # ID of the parent "dbaas" group
GITLAB_REQUEST_CONCURRENCY=20             # max concurrent HTTP requests to GitLab

# ── ArgoCD ───────────────────────────────────────────────────────────────────
# JSON array — must be a single line in this file (no line breaks inside the value).
# Set to [] to disable ArgoCD scanning.
ARGOCD_INSTANCES=[{"cluster_name":"cluster-prod-1","url":"https://argocd1.example.com","token":"ey..."},{"cluster_name":"cluster-prod-2","url":"https://argocd2.example.com","token":"ey..."}]

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=json                      # "json" or "mongodb"
STORAGE_JSON_PATH=data/databases.json     # only used when STORAGE_BACKEND=json
# MONGO_URI=mongodb://user:pass@host:27017    # required when STORAGE_BACKEND=mongodb
# STORAGE_MONGO_DATABASE=dbaas

# ── Scanning ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300                 # auto-scan interval in seconds (0 = disabled)

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=changeme                  # generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin       # username for the auto-created first admin user
AUTH_BOOTSTRAP_ADMIN_PASSWORD=changeme    # set on first deploy to create admin; clear afterwards
